# Compose-level variables used by docker-compose.prod.yml
# Copy to .env.prod on your VPS and edit values.

# Frontend build-time public URLs (these are baked into Next.js during image build)
NEXT_PUBLIC_API_URL=https://stocknest.cloud
NEXT_PUBLIC_WS_URL=wss://stocknest.cloud/api/v1/integrations/ws/sales

# Backend runtime flags
ENVIRONMENT=production
DEBUG=False
RUN_MIGRATIONS_ON_STARTUP=true

# Container port bindings on VPS host.
# For nginx/traefik reverse proxy on host, keep 127.0.0.1 binding.
# For direct public exposure, switch to 3000:3000 and 8000:8000.
FRONTEND_BIND=127.0.0.1:3000:3000
BACKEND_BIND=127.0.0.1:8000:8000
