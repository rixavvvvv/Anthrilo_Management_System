# Backend API URL
# Local dev: http://127.0.0.1:8000
# Production: https://your-backend-domain.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional explicit WebSocket URL
# Local dev: ws://127.0.0.1:8000/api/v1/integrations/ws/sales
# Production: wss://your-backend-domain.com/api/v1/integrations/ws/sales
NEXT_PUBLIC_WS_URL=
