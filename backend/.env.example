# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Database (Supabase PostgreSQL - using connection pooler port 6543)
# Note: @ symbol in password is encoded as %40
DATABASE_URL=postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# Redis
# Local dev: redis://localhost:6379
# Docker: redis://redis:6379 (auto-set by docker-compose)
REDIS_URL=redis://localhost:6379

# Security - IMPORTANT: Change SECRET_KEY in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-characters-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development
DEBUG=True

# CORS - Add your frontend URLs
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Anthrilo Management System

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Unicommerce API Configuration
# AUTO-AUTHENTICATION: System automatically generates and refreshes tokens
# Just provide username/password - tokens are managed automatically
UNICOMMERCE_TENANT=your-tenant-name
UNICOMMERCE_ACCESS_CODE=your-access-code-here
UNICOMMERCE_USERNAME=your-unicommerce-email@example.com
UNICOMMERCE_PASSWORD=your-unicommerce-password
UNICOMMERCE_ACCESS_TOKEN=
UNICOMMERCE_REFRESH_TOKEN=
# Note: Leave ACCESS_TOKEN and REFRESH_TOKEN empty - they auto-generate on first API call
